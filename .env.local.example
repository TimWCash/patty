# Microsoft Entra ID (Azure AD) sign-in for Patty.
# Copy this file to .env.local and fill in values from your Entra app registration,
# then restart the dev server. Without these, Patty runs open (no sign-in gate).
#
# In the Azure portal: Entra ID > App registrations > New registration.
#   - Redirect URI (Web):  http://localhost:3100/api/auth/callback
#     (add your production URL too when you deploy)
#   - API permissions: Microsoft Graph > Delegated > User.Read, Mail.Read,
#     Files.Read.All, Sites.Read.All, openid, profile, email, offline_access
#     (Sites.Read.All / Files.Read.All may need admin consent — grant it once)
#   - Certificates & secrets: create a client secret, copy its *value*
# Powers: Microsoft sign-in + roles, Outlook email, OneDrive + SharePoint documents.

AZURE_AD_TENANT_ID=your-tenant-id        # or "common" / "organizations"
AZURE_AD_CLIENT_ID=your-application-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret-value

# Optional: a random string used to sign the session cookie.
# If omitted, the client secret is used as the signing key.
AUTH_SECRET=generate-a-long-random-string

# Optional: comma-separated emails that should be Admins on first sign-in.
# (Otherwise the very first person to sign in becomes Admin.)
ADMIN_EMAILS=you@servicephysics.com

# ClickUp, SharePoint site, and meeting-notes credentials are entered in-app
# under Connections (Settings) — no env vars needed for those.

# Patty AI assistant (separate from sign-in)
# ANTHROPIC_API_KEY=sk-ant-...
